{
  "name": "pseo-engine",
  "version": "1.0.0",
  "description": "Plug-and-play programmatic SEO engine for any site type. Generate thousands of keyword-targeted landing pages without touching your design.",
  "main": "engine/cli.js",
  "bin": {
    "pseo-engine": "./engine/cli.js"
  },
  "scripts": {
    "start": "node engine/cli.js",
    "test": "npm run build:saas && npm run build:blog && npm run build:ecom",
    "build:saas": "node engine/cli.js build --config examples/saas-example/pseo.config.json",
    "build:blog": "node engine/cli.js build --config examples/blog-example/pseo.config.json",
    "build:ecom": "node engine/cli.js build --config examples/ecom-example/pseo.config.json"
  },
  "keywords": [
    "seo", "programmatic-seo", "landing-pages", "static-site", "nextjs", "astro"
  ],
  "author": "Madhav Shankar",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "chalk": "^5.3.0",
    "csv-parse": "^5.5.6",
    "fast-xml-parser": "^4.3.6",
    "inquirer": "^9.2.20",
    "node-fetch": "^3.3.2",
    "openai": "^4.47.1",
    "ora": "^8.0.1",
    "yargs": "^17.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module"
}
